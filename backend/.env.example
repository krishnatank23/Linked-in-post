APP_NAME=LinkedIn Personal Branding Assistant
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./linkedin_branding.db
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_TIMEOUT_SECONDS=60
DUCKDUCKGO_MAX_RESULTS=10
MAX_INFLUENCERS=15
OUTLOOK_SMTP_HOST=smtp.office365.com
OUTLOOK_SMTP_PORT=587
OUTLOOK_SMTP_USERNAME=your_outlook_email@outlook.com
OUTLOOK_SMTP_PASSWORD=your_outlook_password_or_app_password
OUTLOOK_FROM_EMAIL=your_outlook_email@outlook.com
